extends layout

block content
  .row
    .col-md-12
      .d-flex.justify-content-between.align-items-center.mb-4
        h1.mb-0 📋 Daftar Mahasiswa
        a.btn.btn-primary(href='/tambah')
          span ➕ Tambah Mahasiswa

  .row
    .col-md-12
      if mahasiswa && mahasiswa.length > 0
        .card
          .table-responsive
            table.table.table-hover.mb-0
              thead.table-light
                tr
                  th.text-center # 
                  th Nama
                  th Email
                  th Jurusan
                  th.text-center Aksi
              tbody
                - var no = 1;
                each item in mahasiswa
                  tr
                    td.text-center= no++
                    td= item.nama
                    td= item.email
                    td= item.jurusan
                    td.text-center
                      a.btn.btn-sm.btn-warning(href='/edit/' + item.id) ✏️ Edit
                      |  
                      a.btn.btn-sm.btn-danger(href='/hapus/' + item.id, onclick='return confirm("Yakin ingin menghapus?")') 🗑️ Hapus
      else
        .alert.alert-info.text-center
          h5.mb-0 📭 Belum ada data mahasiswa
          p.mb-0 Silahkan tambahkan data terlebih dahulu
          a.btn.btn-primary.mt-3(href='/tambah') Tambah Mahasiswa Pertama
